            "body": {
              "mode": "raw",
              "raw": "{\n  \"orderId\": 1,\n  \"productId\": 1,\n  \"quantity\": 5,\n  \"unitPrice\": 2999.99\n}"
            }
          }
        },
        {
          "name": "Delete Order Item",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/orderitems/1/1"
          }
        }
      ]
    }
  ]
}
